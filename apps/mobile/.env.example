# Expo Environment Variables
# Prefix with EXPO_PUBLIC_ to expose them to the client bundle.

# The Facebook/Meta App ID required for sharing to Instagram Stories (must be a numeric string)
# You can obtain this by registering your app at https://developers.facebook.com/
EXPO_PUBLIC_APP_ID=123456789012345

# The Play Store URL for sharing attribution
EXPO_PUBLIC_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=com.grovkornet.app
