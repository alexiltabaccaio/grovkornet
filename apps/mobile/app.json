{
  "expo": {
    "name": "Grovkornet",
    "slug": "Grovkornet",
    "version": "0.10.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "backgroundColor": "#0e0e0e",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0e0e0e"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Grovkornet needs camera access to capture cinematic footage with real-time analog film emulation.",
        "NSMicrophoneUsageDescription": "Grovkornet needs microphone access to record high-quality audio for your cinematic videos."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#151515"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.grovkornet.app",
      "versionCode": 1
    },
    "androidNavigationBar": {
      "backgroundColor": "#0e0e0e"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-asset",
      "expo-font",
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Grovkornet to access your photos to save and view cinematic clips.",
          "savePhotosPermission": "Allow Grovkornet to save cinematic clips to your photos."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26
          }
        }
      ]
    ]
  }
}