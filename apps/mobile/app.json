{
  "expo": {
    "name": "Grovkornet",
    "slug": "Grovkornet",
    "version": "0.10.3",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "backgroundColor": "#0e0e0e",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Grovkornet needs camera access to capture cinematic footage with real-time analog film emulation.",
        "NSMicrophoneUsageDescription": "Grovkornet needs microphone access to record high-quality audio for your cinematic videos."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#151515"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED"
      ],
      "package": "com.grovkornet.app",
      "versionCode": 6
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-asset",
      "expo-font",
      "expo-image",
      "expo-localization",
      "expo-status-bar",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#0e0e0e"
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Grovkornet to access your photos to save and view cinematic clips.",
          "savePhotosPermission": "Allow Grovkornet to save cinematic clips to your photos."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26,
            "targetSdkVersion": 35
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "0ceec06e-0882-4742-8b49-596a81072198"
      }
    },
    "owner": "alexgiustizieri"
  }
}
