{
  "name": "@grovkornet/mobile",
  "version": "0.11.2",
  "description": "A high-performance cinematic camera application for Android built with React Native and a custom C++/Kotlin native rendering engine (Uber Shader) for real-time analog film emulation.",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "dev": "expo run:android --variant developmentDebug --app-id com.grovkornet.app.dev",
    "android": "expo run:android --variant developmentDebug --app-id com.grovkornet.app.dev",
    "build": "expo run:android --variant productionRelease --app-id com.grovkornet.app",
    "web": "expo start --web",
    "test": "jest",
    "test:mutation": "stryker run",
    "lint": "npx tsc --noEmit && eslint .",
    "lint:fix": "eslint . --fix"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "./jest.setup.ts"
    ],
    "testPathIgnorePatterns": [
      "<rootDir>/.stryker-tmp/"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|expo-image|expo-sensors)"
    ]
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@grovkornet/engine": "file:../../packages/engine",
    "@grovkornet/shared": "file:../../packages/shared",
    "expo": "~56.0.0",
    "expo-asset": "~56.0.15",
    "expo-build-properties": "~56.0.16",
    "expo-file-system": "~56.0.7",
    "expo-font": "~56.0.5",
    "expo-haptics": "~56.0.3",
    "expo-image": "~56.0.9",
    "expo-localization": "~56.0.6",
    "expo-media-library": "~56.0.6",
    "expo-sensors": "~56.0.5",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "i18next": "^26.1.0",
    "react": "19.2.3",
    "react-i18next": "^17.0.7",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-mmkv": "^4.3.1",
    "react-native-nitro-modules": "^0.35.7",
    "react-native-reanimated": "4.4.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-share": "^12.3.1",
    "react-native-worklets": "0.9.1",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@conarti/eslint-plugin-feature-sliced": "^1.0.5",
    "@react-native/jest-preset": "^0.85.3",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/jest-runner": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.9.1",
    "@types/react": "~19.2.14",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@welldone-software/why-did-you-render": "^10.0.1",
    "babel-plugin-transform-remove-console": "^6.9.4",
    "eslint": "^9.39.4",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-i18next": "^6.1.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-native": "^5.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "eslint-plugin-zustand": "^1.0.2",
    "jest": "^29.7.0",
    "jest-expo": "~56.0.4",
    "react-test-renderer": "^19.2.3",
    "typescript": "~6.0.3"
  },
  "license": "UNLICENSED",
  "private": true,
  "overrides": {
    "@xmldom/xmldom": "^0.9.10",
    "postcss": "^8.5.10",
    "tar": "^7.5.15",
    "@tootallnate/once": "^2.0.1"
  },
  "expo": {
    "doctor": {
      "appConfigFieldsNotSyncedCheck": {
        "enabled": false
      }
    },
    "install": {
      "exclude": [
        "react-native-reanimated",
        "react-native-worklets",
        "expo",
        "expo-asset",
        "expo-build-properties",
        "expo-file-system",
        "expo-font",
        "expo-image",
        "expo-media-library",
        "expo-sensors",
        "jest-expo"
      ]
    }
  }
}
