{
  "name": "@grovkornet/mobile",
  "version": "0.9.0",
  "description": "A high-performance cinematic camera application for Android built with React Native and a custom C++/Kotlin native rendering engine (Uber Shader) for real-time analog film emulation.",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "dev": "expo run:android",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "build": "expo run:android --variant release",
    "web": "expo start --web",
    "test": "jest",
    "lint": "npx tsc --noEmit && eslint .",
    "lint:fix": "eslint . --fix"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "./jest.setup.ts"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|expo-image|expo-sensors)"
    ]
  },
  "dependencies": {
    "@expo/vector-icons": "~14.0.4",
    "@grovkornet/engine": "file:../../packages/engine",
    "@grovkornet/shared": "file:../../packages/shared",
    "expo": "52.0.49",
    "expo-asset": "~11.0.5",
    "expo-blur": "~14.0.3",
    "expo-build-properties": "~0.13.3",
    "expo-font": "~13.0.4",
    "expo-haptics": "~14.0.1",
    "expo-image": "~2.0.7",
    "expo-localization": "~16.0.1",
    "expo-media-library": "~17.0.6",
    "expo-sensors": "~14.0.2",
    "expo-status-bar": "~2.0.1",
    "expo-system-ui": "~4.0.9",
    "expo-updates": "^0.27.5",
    "i18next": "^26.1.0",
    "react": "18.3.1",
    "react-i18next": "^17.0.7",
    "react-native": "0.76.9",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-mmkv": "^4.3.1",
    "react-native-nitro-modules": "^0.35.7",
    "react-native-reanimated": "~3.16.1",
    "react-native-share": "^12.3.1",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~18.3.12",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@welldone-software/why-did-you-render": "^10.0.1",
    "babel-plugin-transform-remove-console": "^6.9.4",
    "eslint": "^9.39.4",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-native": "^5.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "jest": "^29.7.0",
    "jest-expo": "^52.0.3",
    "react-test-renderer": "^18.2.0",
    "typescript": "~5.3.3"
  },
  "license": "UNLICENSED",
  "private": true,
  "overrides": {
    "@xmldom/xmldom": "^0.9.10",
    "postcss": "^8.5.10",
    "tar": "^7.5.15",
    "@tootallnate/once": "^2.0.1"
  }
}
