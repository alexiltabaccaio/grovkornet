{
  "cli": {
    "version": ">= 10.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "image": "ubuntu-24.04-jdk-17-ndk-r27b-sdk-55",
        "gradleCommand": ":app:assembleDevelopmentDebug"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "app-bundle",
        "image": "ubuntu-24.04-jdk-17-ndk-r27b-sdk-55",
        "gradleCommand": ":app:bundleProductionRelease"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle",
        "image": "ubuntu-24.04-jdk-17-ndk-r27b-sdk-55",
        "gradleCommand": ":app:bundleProductionRelease"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "track": "production"
      }
    },
    "internal": {
      "android": {
        "track": "internal"
      }
    },
    "alpha": {
      "android": {
        "track": "alpha"
      }
    },
    "beta": {
      "android": {
        "track": "beta"
      }
    }
  }
}


