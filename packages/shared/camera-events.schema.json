{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CameraEvents",
  "type": "object",
  "required": ["events"],
  "properties": {
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "scope", "frequency", "properties"],
        "properties": {
          "name": { "type": "string" },
          "scope": { "type": "string", "enum": ["view", "module"] },
          "frequency": { "type": "string", "enum": ["low", "high"] },
          "properties": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "type"],
              "properties": {
                "name": { "type": "string" },
                "type": { "type": "string", "enum": ["number", "string", "boolean", "array", "object"] },
                "optional": { "type": "boolean" },
                "enum": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "properties": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["name", "type"],
                    "properties": {
                      "name": { "type": "string" },
                      "type": { "type": "string", "enum": ["number", "string", "boolean"] },
                      "optional": { "type": "boolean" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
