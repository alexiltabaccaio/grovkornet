material {
    name : "CompositeShader",
    shadingModel : unlit,
    parameters : [
        { type : sampler2d, name : u_Texture },
        { type : sampler2d, name : u_BloomTexture },
        { type : float, name : u_GrainIntensity },
        { type : float, name : u_GrainChroma },
        { type : float, name : u_GrainSize },
        { type : float, name : u_GrainSpeed },
        { type : float, name : u_GrainRoughness },
        { type : float, name : u_VignetteIntensity },
        { type : float, name : u_ChromaShift },
        { type : float, name : u_ChromaShiftDirection },
        { type : float, name : u_ChromaShiftInvert },
        { type : float, name : u_TapeJitter },
        { type : float, name : u_Scanlines },
        { type : float, name : u_ScanlinesHorizontal },
        { type : float, name : u_ScanlinesDensity },
        { type : float, name : u_Time },
        { type : float, name : u_BloomIntensity },
        { type : float, name : u_ChromaticAberration },
        { type : float, name : u_InvertYShift },
        { type : float, name : u_AberrationInvert },
        { type : sampler2d, name : u_OverlayTexture },
        { type : float, name : u_OverlayEnabled },
        { type : float, name : u_DrsScale },
        { type : float, name : u_Sharpening },
        { type : float2, name : u_TexelSize },
        { type : float, name : u_TargetResolution },
        { type : sampler2d, name : u_GlassTexture },
        { type : float, name : u_PixelationFactor },
        { type : float, name : u_PanelY }
    ],
    requires : [ uv0 ]
}

fragment {
    #include "includes/Pixelation.glsl"
    #include "includes/ChromaEffects.glsl"
    #include "includes/Sharpening.glsl"
    #include "includes/Scanlines.glsl"
    #include "includes/Vignette.glsl"
    #include "includes/FilmGrain.glsl"
    #include "includes/Glassmorphism.glsl"

    void material(inout MaterialInputs material) {
        prepareMaterial(material);
        vec2 uv = getUV0();
        vec2 res = 1.0 / materialParams.u_TexelSize;
        float minDim = min(res.x, res.y);
        
        // 1. Pixelation & DRS scale
        uv = applyPixelation(uv, res, minDim);

        // 2. Chromatic aberration, shift and tape jitter UVs
        vec2 rUv, gUv, bUv, compositeUv;
        computeChromaUvs(uv, res, rUv, gUv, bUv, compositeUv);

        // 3. Texture base color sampling
        vec4 baseColor;
        bool hasChromaEffects = materialParams.u_ChromaShift > 0.0 || materialParams.u_ChromaticAberration > 0.0 || materialParams.u_TapeJitter > 0.0;
        if (hasChromaEffects) {
            vec4 colR = texture(materialParams_u_Texture, rUv);
            vec4 colG = texture(materialParams_u_Texture, gUv);
            vec4 colB = texture(materialParams_u_Texture, bUv);
            baseColor = vec4(colR.r, colG.g, colB.b, colG.a);
        } else {
            baseColor = texture(materialParams_u_Texture, compositeUv);
        }

        // 4. Sharpening filter
        baseColor.rgb = applySharpening(baseColor.rgb, compositeUv);

        // 5. Scanlines
        baseColor.rgb = applyScanlines(baseColor.rgb, uv, res);
        
        vec2 flippedBloomUv = vec2(compositeUv.x, materialParams.u_DrsScale - compositeUv.y);
        vec3 finalColor = baseColor.rgb;

        // 6. Bloom composite
        if (materialParams.u_BloomIntensity > 0.0) {
            vec3 bloomColor = texture(materialParams_u_BloomTexture, flippedBloomUv).rgb;
            // Soft additive blend in linear space
            finalColor += bloomColor * materialParams.u_BloomIntensity;
        }
        
        // 7. Vignette
        finalColor = applyVignette(finalColor, uv);
        
        // 8. Film Grain
        finalColor = applyFilmGrain(finalColor, uv);
        
        // 9. Overlay Texture (Dust & Scratch)
        if (materialParams.u_OverlayEnabled > 0.0) {
            vec4 overlay = textureLod(materialParams_u_OverlayTexture, uv, 0.0);
            finalColor = mix(finalColor, overlay.rgb, overlay.a);
        }
        
        // 10. Glassmorphism blur overlay
        finalColor = applyGlassmorphism(finalColor, uv, flippedBloomUv);
        
        material.baseColor = vec4(finalColor, baseColor.a);
    }
}
