material {
    name : "CompositeShader",
    shadingModel : unlit,
    parameters : [
        { type : sampler2d, name : u_Texture },
        { type : sampler2d, name : u_BloomTexture },
        { type : sampler2d, name : u_OverlayTexture },
        { type : sampler2d, name : u_GlassTexture },
        { type : float4, name : u_RenderData0 },
        { type : float4, name : u_RenderData1 },
        { type : float4, name : u_RenderData2 },
        { type : float4, name : u_RenderData3 },
        { type : float4, name : u_RenderData4 },
        { type : float4, name : u_RenderData5 },
        { type : float4, name : u_RenderData6 },
        { type : float4, name : u_RenderData7 }
    ],
    requires : [ uv0 ]
}

fragment {
    #define u_GrainIntensity u_RenderData0.x
    #define u_GrainChroma u_RenderData0.y
    #define u_GrainSize u_RenderData0.z
    #define u_GrainSpeed u_RenderData0.w
    #define u_GrainRoughness u_RenderData1.x
    #define u_VignetteIntensity u_RenderData1.y
    #define u_ChromaShift u_RenderData1.z
    #define u_ChromaShiftDirection u_RenderData1.w
    #define u_ChromaShiftInvert u_RenderData2.x
    #define u_TapeJitter u_RenderData2.y
    #define u_Scanlines u_RenderData2.z
    #define u_ScanlinesHorizontal u_RenderData2.w
    #define u_ScanlinesDensity u_RenderData3.x
    #define u_Time u_RenderData3.y
    #define u_BloomIntensity u_RenderData3.z
    #define u_ChromaticAberration u_RenderData3.w
    #define u_InvertYShift u_RenderData4.x
    #define u_AberrationInvert u_RenderData4.y
    #define u_OverlayEnabled u_RenderData4.z
    #define u_DrsScale u_RenderData4.w
    #define u_Sharpening u_RenderData5.x
    #define u_TexelSize u_RenderData5.yz
    #define u_TargetResolution u_RenderData5.w
    #define u_PixelationFactor u_RenderData6.x
    #define u_PanelY u_RenderData6.y
    #define u_LensDistortion u_RenderData6.z
    #define u_HalationIntensity u_RenderData6.w
    #define u_BloomThreshold u_RenderData7.x
    #define u_HalationThreshold u_RenderData7.y
    #define u_ChromaBleed u_RenderData7.z
    #define u_DeviceOrientation u_RenderData7.w

    #include "includes/Pixelation.glsl"
    #include "includes/ChromaEffects.glsl"
    #include "includes/Sharpening.glsl"
    #include "includes/Scanlines.glsl"
    #include "includes/Vignette.glsl"
    #include "includes/FilmGrain.glsl"
    #include "includes/Glassmorphism.glsl"
    #include "includes/LensDistortion.glsl"

    vec4 sampleTextureWithPixelationBlur(vec2 uv, vec2 blurOffset) {
        if (blurOffset.x == 0.0) {
            return texture(materialParams_u_Texture, uv);
        } else {
            vec4 c = texture(materialParams_u_Texture, uv);
            c += texture(materialParams_u_Texture, uv + vec2(blurOffset.x, blurOffset.y));
            c += texture(materialParams_u_Texture, uv + vec2(-blurOffset.x, blurOffset.y));
            c += texture(materialParams_u_Texture, uv + vec2(blurOffset.x, -blurOffset.y));
            c += texture(materialParams_u_Texture, uv + vec2(-blurOffset.x, -blurOffset.y));
            return c * 0.2;
        }
    }

    void material(inout MaterialInputs material) {
        prepareMaterial(material);
        vec2 uv = getUV0();
        uv = applyLensDistortion(uv);
        vec2 res = 1.0 / materialParams.u_TexelSize;
        float minDim = min(res.x, res.y);
        
        // 1. Pixelation & DRS scale
        uv = applyPixelation(uv, res, minDim);

        // 2. Chromatic aberration, shift and tape jitter UVs
        vec2 rUv, gUv, bUv, compositeUv;
        computeChromaUvs(uv, res, rUv, gUv, bUv, compositeUv);

        // 3. Texture base color sampling
        vec4 baseColor;
        
        vec2 blurOffset = vec2(0.0);
        if (materialParams.u_PixelationFactor > 1.0) {
            float maxDim = max(res.x, res.y);
            float scaledFactor = max(1.0, materialParams.u_PixelationFactor * (maxDim / 1920.0));
            blurOffset = (1.0 / (res / scaledFactor)) * 0.35;
        }

        bool hasChromaEffects = materialParams.u_ChromaShift > 0.0 || materialParams.u_ChromaticAberration > 0.0 || materialParams.u_TapeJitter > 0.0;
        if (hasChromaEffects) {
            vec4 colR = sampleTextureWithPixelationBlur(rUv, blurOffset);
            vec4 colG = sampleTextureWithPixelationBlur(gUv, blurOffset);
            vec4 colB = sampleTextureWithPixelationBlur(bUv, blurOffset);
            baseColor = vec4(colR.r, colG.g, colB.b, colG.a);
        } else {
            baseColor = sampleTextureWithPixelationBlur(compositeUv, blurOffset);
        }

        if (materialParams.u_PixelationFactor <= 1.0) {
            // Apply Chroma Bleed
            baseColor.rgb = applyChromaBleed(baseColor.rgb, compositeUv);

            // 4. Sharpening filter
            baseColor.rgb = applySharpening(baseColor.rgb, compositeUv);
        }

        // 5. Scanlines
        baseColor.rgb = applyScanlines(baseColor.rgb, uv, res);
        
        vec2 flippedBloomUv = vec2(compositeUv.x, materialParams.u_DrsScale - compositeUv.y);
        vec3 finalColor = baseColor.rgb;

        // 6. Bloom & Halation composite
        vec3 bloomColor = texture(materialParams_u_BloomTexture, flippedBloomUv).rgb;
        if (materialParams.u_BloomIntensity > 0.0) {
            float bloomLum = dot(bloomColor, vec3(0.299, 0.587, 0.114));
            float actualBloomThreshold = 1.0 - materialParams.u_BloomThreshold;
            float bloomMask = smoothstep(actualBloomThreshold, 1.01, bloomLum);
            finalColor += bloomColor * bloomMask * materialParams.u_BloomIntensity;
        }

        if (materialParams.u_HalationIntensity > 0.0) {
            vec3 halationTint = vec3(1.0, 0.25, 0.05); 
            float halationLum = dot(bloomColor, vec3(0.299, 0.587, 0.114));
            float actualHalationThreshold = 1.0 - materialParams.u_HalationThreshold;
            float halationMask = smoothstep(actualHalationThreshold, 1.01, halationLum);
            finalColor += bloomColor * halationTint * halationMask * materialParams.u_HalationIntensity;
        }
        
        // 7. Vignette
        finalColor = applyVignette(finalColor, uv);
        
        // 8. Film Grain
        finalColor = applyFilmGrain(finalColor, uv);
        
        // 9. Overlay Texture (Dust & Scratch)
        if (materialParams.u_OverlayEnabled > 0.0) {
            vec4 overlay = textureLod(materialParams_u_OverlayTexture, uv, 0.0);
            finalColor = mix(finalColor, overlay.rgb, overlay.a);
        }
        
        // 10. Glassmorphism blur overlay
        finalColor = applyGlassmorphism(finalColor, uv, flippedBloomUv);
        
        material.baseColor = vec4(finalColor, baseColor.a);
    }
}
