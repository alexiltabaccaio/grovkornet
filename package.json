{
  "name": "grovkornet-monorepo",
  "version": "0.10.0",
  "private": true,
  "packageManager": "npm@10.8.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "installConfig": {
    "hoistingLimits": "workspaces"
  },
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@grovkornet/web",
    "dev:android": "node packages/shared/scripts/watch-codegen.js --device",
    "dev:android_sim": "node packages/shared/scripts/watch-codegen.js --simulator",
    "dev:mobile": "node packages/shared/scripts/watch-codegen.js --device",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=@grovkornet/web",
    "build:android": "npm run codegen && node packages/shared/scripts/build-android.js --device",
    "build:android_sim": "npm run codegen && node packages/shared/scripts/build-android.js --simulator",
    "build:mobile": "npm run codegen && node packages/shared/scripts/build-android.js --device",
    "codegen": "node packages/shared/scripts/codegen-parameters.js && node packages/shared/scripts/codegen-errors.js && node packages/shared/scripts/graphrag/builder.js",
    "lint": "turbo run lint",
    "android": "npm run android -w @grovkornet/mobile",
    "ios": "npm run ios -w @grovkornet/mobile",
    "release": "commit-and-tag-version"
  },
  "devDependencies": {
    "commit-and-tag-version": "^12.7.3",
    "turbo": "^2.3.3"
  },
  "dependencies": {
    "expo": "~52.0.49",
    "react": "18.3.1",
    "react-native": "0.76.9"
  }
}
