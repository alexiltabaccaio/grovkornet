{
  "name": "grovkornet-monorepo",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@10.8.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "installConfig": {
    "hoistingLimits": "workspaces"
  },
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@grovkornet/web",
    "dev:android": "turbo run dev --filter=@grovkornet/mobile",
    "dev:mobile": "turbo run dev --filter=@grovkornet/mobile",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=@grovkornet/web",
    "build:android": "turbo run build --filter=@grovkornet/mobile",
    "build:mobile": "turbo run build --filter=@grovkornet/mobile",
    "lint": "turbo run lint"
  },
  "devDependencies": {
    "turbo": "^2.3.3"
  }
}
