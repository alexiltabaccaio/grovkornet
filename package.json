{
  "name": "grovkornet-monorepo",
  "version": "0.11.2",
  "private": true,
  "packageManager": "npm@10.8.1",
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/shared/scripts/graphrag"
  ],
  "installConfig": {
    "hoistingLimits": "workspaces"
  },
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@grovkornet/web",
    "dev:android": "node apps/mobile/scripts/watch.js --device",
    "dev:android_sim": "node apps/mobile/scripts/watch.js --simulator",
    "dev:mobile": "node apps/mobile/scripts/watch.js --device",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=@grovkornet/web",
    "build:android": "npm run codegen && node apps/mobile/scripts/android/build.js --device",
    "build:android_sim": "npm run codegen && node apps/mobile/scripts/android/build.js --simulator",
    "build:mobile": "npm run codegen && node apps/mobile/scripts/android/build.js --device",
    "codegen": "node packages/shared/scripts/codegen/index.js && node packages/shared/scripts/graphrag/src/cli/build.js",
    "lint:graphrag": "node packages/shared/scripts/graphrag/src/cli/build.js && node packages/shared/scripts/graphrag/src/cli/analyze.js",
    "lint": "turbo run lint && npm run lint:graphrag && node scripts/check-worklet-captures.js",
    "lint:worklets": "node scripts/check-worklet-captures.js",
    "test:mutation:codegen": "npm run stryker -w @grovkornet/shared",
    "test:mutation:mobile": "stryker run stryker.mobile.config.json",
    "test:mutation:mobile:file": "stryker run stryker.mobile.config.json --mutate",
    "android": "npm run codegen && npm run android -w @grovkornet/mobile",
    "release": "commit-and-tag-version",
    "postinstall": "patch-package"
  },
  "devDependencies": {
    "commit-and-tag-version": "^12.7.3",
    "nitrogen": "0.36.1",
    "patch-package": "^8.0.1",
    "react-test-renderer": "19.2.3",
    "turbo": "^2.3.3"
  },
  "dependencies": {
    "expo": "~56.0.0",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-reanimated": "4.4.1",
    "react-native-worklets": "0.9.1"
  },
  "overrides": {
    "react-test-renderer": "19.2.3",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  }
}
